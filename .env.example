# 프록시 → Juice Shop (docker-compose.yml 의 호스트 포트와 같아야 함. 기본 3001)
# 호스트 포트를 바꿨다면 여기도 같이 수정 (예: http://127.0.0.1:3002)
UPSTREAM_URL=http://127.0.0.1:3001

# 다른 머신에만 Juice Shop이 있으면 예: UPSTREAM_URL=http://192.168.0.20:3001

# LAN에서 다른 사람이 프록시에 붙게 하려면 uvicorn 을 0.0.0.0 에 바인딩:
#   uvicorn main:app --host 0.0.0.0 --port 8080
# (자세한 명령은 JUICE_SHOP_NETWORK_SETUP.md 참고)

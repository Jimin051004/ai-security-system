# 업스트림 웹 앱 베이스 URL (Juice Shop, DVWA, 자체 앱 등 무엇이든)
# docker-compose 기본 호스트 포트 3001 예시:
UPSTREAM_URL=http://127.0.0.1:3001
# 다른 호스트/포트 예: http://192.168.0.20:3001  https://internal.example.com

# WAF: 요청 스캔 후 심각도가 이 값 이상이면 403 (none|low|medium|high|critical)
WAF_BLOCK_MIN_SEVERITY=high
# WAF 끄기(프록시만): WAF_ENABLED=false
# WAF_ENABLED=true
# 본문 프리뷰 최대 바이트 (모듈에 넘기는 크기)
# WAF_BODY_PREVIEW_MAX=8192

# LAN에서 다른 사람이 프록시에 붙게 하려면 uvicorn 을 0.0.0.0 에 바인딩:
#   uvicorn main:app --host 0.0.0.0 --port 8080
# (자세한 명령은 docs/JUICE_SHOP_NETWORK_SETUP.md 참고)
#
# 프록시는 HTML/JS/JSON 안의 http://127.0.0.1:3001 같은 절대 URL을
# 클라이언트가 접속한 호스트(예: http://192.168.x.x:8080)로 치환합니다.
# 본문 치환 최대 크기(바이트, 기본 6MiB): PROXY_REWRITE_MAX_BYTES=6291456
